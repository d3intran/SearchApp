{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "StandardQuery",
  "version": "0.1.0",
  "identifier": "com.gky.standardquery",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "deno run -A npm:vite --port 1420",
    "beforeBuildCommand": "deno run -A npm:vite build"
  },
  "app": {
    "windows": [
      {
        "title": "标准综合查询器",
        "width": 1100,
        "height": 720,
        "center": true,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
